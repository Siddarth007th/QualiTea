# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qa_tracker

# SMTP (Ethereal test account — replace with real credentials in production)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_ethereal_user@ethereal.email
SMTP_PASS=your_ethereal_password

# Manager email (receives Fail / Semi-Pass alerts)
MANAGER_EMAIL=manager@example.com

PORT=5000
